model MedicalReport {
  id           String   @id @default(uuid())
  patientId    String
  reportName   String
  reportLink   String?
  reportImages String[] 

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient      Patient  @relation(fields: [patientId], references: [id])

  @@map("medical_reports")
}
